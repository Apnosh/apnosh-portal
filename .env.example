# Apnosh Portal environment variables.
# Copy this file to .env.local and fill in the values.
# The real values are NOT in this repo. The owner shares them privately.
# These point at the LIVE Supabase backend, so saved data is real.

# --- Supabase (database + auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (billing) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google (Business Profile + Places) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_PLACES_KEY=

# --- Meta / Instagram ---
META_APP_ID=
META_APP_SECRET=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CM_CLIENT_ID=
LINKEDIN_CM_CLIENT_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Anthropic (AI features) ---
ANTHROPIC_API_KEY=
