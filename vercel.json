{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/gbp-ingest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/gbp-api-sync",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/gbp-client-sync",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/run-operator",
      "schedule": "0 15 * * 1"
    },
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/fetch-reviews",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/holiday-hours-check",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/ga-sync",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/gsc-sync",
      "schedule": "45 13 * * *"
    }
  ]
}
